{{- $authorEmail := partial "rss/helpers/GetAuthorEmail" -}}
{{- $authorName := partial "rss/helpers/GetAuthorName" -}}
{{- $pages := partial "rss/helpers/GetPages" . -}}
{{- $lastBuildDate := (index $pages.ByLastmod.Reverse 0).Lastmod -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<!DOCTYPE rss PUBLIC "-//Netscape Communications//DTD RSS 0.91//EN" "http://my.netscape.com/publish/formats/rss-0.91.dtd">
<rss  version="2.0"
      xmlns:atom="http://www.w3.org/2005/Atom"
      xmlns:content="http://purl.org/rss/1.0/modules/content/"
      xmlns:dc="http://purl.org/dc/elements/1.1/"
      xmlns:ev="http://purl.org/rss/1.0/modules/event/"
      xmlns:media="http://search.yahoo.com/mrss/"
      >
  <channel>
    {{ partial "rss/channel.html" (dict
      "context" .
      "authorName" $authorName
      "authorName" $authorEmail
      "lastBuildDate" $lastBuildDate
    ) }}
    {{- range $pages }}
      {{ partial "rss/item.html" (dict
        "item" .
        "authorName" $authorName
        "authorName" $authorEmail
      ) }}
    {{- end }}
  </channel>
</rss>
